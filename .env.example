# ==========================================
# AUTHENTICATION (Clerk)
# ==========================================
# Get your keys from https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ==========================================
# DATABASE (Astra DB - DataStax)
# ==========================================
# Create a free database at https://astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:...
ASTRA_DB_API_ENDPOINT=https://<db-id>-<region>.apps.astra.datastax.com
ASTRA_DB_NAMESPACE=trading_agent

# ==========================================
# AI (Groq)
# ==========================================
# Get your API key from https://console.groq.com
GROQ_API_KEY=gsk_...

# ==========================================
# SOLANA RPC
# ==========================================
# Use a public RPC endpoint or get a key from Helius/QuickNode
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ==========================================
# DATA APIs (Optional but recommended)
# ==========================================
# Birdeye API - Get from https://birdeye.so
BIRDEYE_API_KEY=

# Jupiter API - Get from https://jup.ag
JUPITER_API_KEY=

# Helius API (for webhooks) - Get from https://helius.dev
HELIUS_API_KEY=

# ==========================================
# APP CONFIGURATION
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# AUTONOMOUS TRADING CONFIGURATION
# ==========================================
# WARNING: Set to true to enable autonomous trading (real money!)
AUTO_TRADING_ENABLED=false

# Scan interval in milliseconds (default: 60 seconds)
SCAN_INTERVAL_MS=60000

# Minimum confidence score to execute a trade (0-100)
MIN_CONFIDENCE_SCORE=75

# Maximum amount in USD per trade
MAX_TRADE_AMOUNT_USD=100

# Slippage tolerance in basis points (50 = 0.5%)
SLIPPAGE_BPS=50

# Maximum number of concurrent open trades
MAX_CONCURRENT_TRADES=3

# Minimum liquidity in USD for a token to be considered
MIN_LIQUIDITY_USD=10000

# Minimum 24h volume in USD for a token to be considered
MIN_VOLUME_24H_USD=5000

# Risk level: conservative, moderate, aggressive
RISK_LEVEL=moderate
